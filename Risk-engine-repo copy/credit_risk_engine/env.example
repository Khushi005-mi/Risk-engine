##############################################
# CREDIT RISK ENGINE — ENVIRONMENT TEMPLATE
##############################################

# ------------------------------------------------
# ENGINE ENVIRONMENT
# ------------------------------------------------

ENGINE_NAME=credit-risk-engine
ENGINE_ENV=development
ENGINE_REGION=ap-south-1

# Service version must match model_metadata.json
ENGINE_VERSION=1.0.0


# ------------------------------------------------
# MODEL CONFIGURATION
# ------------------------------------------------

ACTIVE_MODEL_VERSION=1.0.0
MODEL_ARTIFACT_PATH=/app/artifacts/model.pkl
FEATURE_PIPELINE_PATH=/app/artifacts/feature_pipeline.pkl
MODEL_METADATA_PATH=/app/artifacts/model_metadata.json
SCHEMA_DEFINITION_PATH=/app/configs/schema_definition.json


# ------------------------------------------------
# BATCH PROCESSING LIMITS
# ------------------------------------------------

MAX_BATCH_FILE_MB=100
MAX_BATCH_ROWS=1000000
MAX_INVALID_ROW_PERCENT=10
MAX_PARALLEL_BATCH_WORKERS=4

BATCH_TIMEOUT_SECONDS=600


# ------------------------------------------------
# INPUT / OUTPUT STORAGE
# ------------------------------------------------

RAW_BATCH_STORAGE_BUCKET=credit-risk-raw-batches
SCORED_BATCH_STORAGE_BUCKET=credit-risk-scored-batches

RAW_BATCH_PREFIX=raw_uploads
SCORED_BATCH_PREFIX=scored_outputs

LOCAL_BATCH_INPUT_DIR=/data/input
LOCAL_BATCH_OUTPUT_DIR=/data/output


# ------------------------------------------------
# DATABASE CONFIGURATION (AUDIT LOGGING)
# ------------------------------------------------

AUDIT_DB_HOST=localhost
AUDIT_DB_PORT=5432
AUDIT_DB_NAME=credit_risk_audit
AUDIT_DB_USER=audit_user
AUDIT_DB_PASSWORD=CHANGE_ME

AUDIT_DB_SSL_MODE=require
AUDIT_DB_POOL_SIZE=10
AUDIT_DB_MAX_OVERFLOW=20


# ------------------------------------------------
# SCHEMA VALIDATION
# ------------------------------------------------

INPUT_SCHEMA_VERSION=1.0
STRICT_SCHEMA_VALIDATION=true
REJECT_EXTRA_COLUMNS=true


# ------------------------------------------------
# DRIFT MONITORING CONFIG
# ------------------------------------------------

DRIFT_BASELINE_FEATURE_PATH=/app/drift/baseline_features.parquet
DRIFT_RESULTS_TABLE=drift_monitoring_results

PSI_WARNING_THRESHOLD=0.2
PSI_CRITICAL_THRESHOLD=0.3

DRIFT_ALERT_EMAIL=risk-alerts@company.com


# ------------------------------------------------
# SECURITY CONFIGURATION
# ------------------------------------------------

ENABLE_PII_REDACTION=true
MASK_ACCOUNT_NUMBERS=true
MASK_ID_NUMBERS=true

SERVICE_AUTH_ENABLED=true
SERVICE_API_TOKEN=CHANGE_ME


# ------------------------------------------------
# LOGGING CONFIGURATION
# ------------------------------------------------

LOG_LEVEL=INFO
LOG_FORMAT=json

LOG_OUTPUT=stdout
LOG_FILE_PATH=/var/log/credit-risk-engine.log

LOG_MAX_FILE_SIZE_MB=50
LOG_BACKUP_COUNT=5


# ------------------------------------------------
# MONITORING & METRICS
# ------------------------------------------------

ENABLE_METRICS=true
METRICS_PORT=9090
METRICS_NAMESPACE=credit_risk_engine

ENABLE_HEALTHCHECK=true
HEALTHCHECK_PORT=8081


# ------------------------------------------------
# FEATURE ENGINEERING SETTINGS
# ------------------------------------------------

FEATURE_HASH_SEED=42
FEATURE_ORDER_ENFORCEMENT=true


# ------------------------------------------------
# REPLAY MODE CONFIG
# ------------------------------------------------

REPLAY_MODE_ENABLED=false
REPLAY_AUDIT_BUCKET=credit-risk-replay
REPLAY_TMP_DIR=/tmp/replay


# ------------------------------------------------
# DOCKER RUNTIME
# ------------------------------------------------

DOCKER_CONTAINER_MEMORY_MB=2048
DOCKER_CONTAINER_CPU_LIMIT=2